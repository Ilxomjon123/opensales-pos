# Bu namuna. Haqiqiy qiymatlar .env'da (gitignore) yoki GitHub Secrets/Vars'da.
# Maxfiy (Secrets): VITE_OWNER_MASTER, VITE_RECOVERY_MASTER, VITE_INTEGRITY_SECRET, VITE_DEFAULT_PIN
# Ochiq (Vars):    VITE_LICENSE_PUBKEY, VITE_TRIAL_DAYS, VITE_SUPPORT_PHONE, VITE_SUPPORT_NAME

# BITTA owner master kalit — login recovery, litsenziya, backup/restore, shifrlash hammasi shu.
# OCHIQ saqlanmaydi — faqat SHA-512 hex hash (kalit so'z kodda yo'q). KALIT'ni UPPERCASE qiling.
# Hash: node -e "console.log(require('crypto').createHash('sha512').update('KALIT'.toUpperCase(),'utf8').digest('hex'))"
VITE_OWNER_MASTER_HASH=
VITE_INTEGRITY_SECRET=
VITE_DEFAULT_PIN=1234
VITE_LICENSE_PUBKEY=
VITE_TRIAL_DAYS=15
VITE_SUPPORT_PHONE=
VITE_SUPPORT_NAME=
VITE_SITE_URL=
# Cloud backup proxy (Cloudflare Worker) URL — OCHIQ (sir emas). Token Worker'da.
# Masalan: https://pos-backup.<subdomain>.workers.dev
VITE_BACKUP_PROXY_URL=
